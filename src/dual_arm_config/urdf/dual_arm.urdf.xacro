<?xml version="1.0"?>
<!--
  Dual-Arm URDF: xArm 7 + HITBOT Z-Arm S922
  Both robots mounted on a shared "world" frame.
  - xArm 7 at origin (0, 0, 0)
  - HITBOT S922 offset 1m to the right on Y axis (0, 1.0, 0)

  Hardware mode is controlled by the 'hw_mode' arg:
    sim   → mock_components/GenericSystem  (for both arms)
    real  → uf_robot_hardware/UFRobotSystemHardware (xArm) +
            hitbot_hardware/HitbotHardwareInterface (HITBOT)
-->
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="dual_arm">

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- Arguments                                                      -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <xacro:arg name="hw_mode"      default="sim"/>   <!-- sim | real -->
  <xacro:arg name="xarm_ip"      default="192.168.1.230"/>
  <xacro:arg name="hitbot_ip"    default="192.168.58.2"/>
  <xacro:arg name="hitbot_port"  default="8080"/>
  <xacro:arg name="hitbot_y"     default="1.0"/>    <!-- Y offset for hitbot -->

  <xacro:property name="hw_mode"     value="$(arg hw_mode)"/>
  <xacro:property name="xarm_ip"     value="$(arg xarm_ip)"/>
  <xacro:property name="hitbot_ip"   value="$(arg hitbot_ip)"/>
  <xacro:property name="hitbot_port" value="$(arg hitbot_port)"/>
  <xacro:property name="hitbot_y"    value="$(arg hitbot_y)"/>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- xArm 7 includes (UFACTORY macro system)                       -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <xacro:property name="is_ros2" value="true"/>
  <xacro:property name="use_xacro_load_yaml" value="true"/>
  <xacro:property name="mesh_suffix" value="stl"/>
  <xacro:property name="mesh_path" value="package://xarm_description/meshes"/>

  <xacro:include filename="$(find xarm_description)/urdf/common/common.material.xacro"/>
  <xacro:include filename="$(find xarm_description)/urdf/common/common.link.xacro"/>
  <xacro:include filename="$(find xarm_description)/urdf/common/common.gazebo.xacro"/>
  <xacro:include filename="$(find xarm_description)/urdf/xarm7/xarm7_robot_macro.xacro"/>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- World link                                                     -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <link name="world"/>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- xArm 7  (at origin)                                            -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <joint name="xarm_world_joint" type="fixed">
    <parent link="world"/>
    <child  link="link_base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Instantiate xArm 7 (no prefix → joints: joint1..joint7) -->
  <xacro:if value="${hw_mode == 'real'}">
    <xacro:xarm7_robot prefix="" hw_ns="xarm" limited="false"
      velocity_control="false" add_gripper="false"
      ros2_control_plugin="uf_robot_hardware/UFRobotSystemHardware"
      robot_ip="${xarm_ip}" report_type="normal"
      model_num="0"
      kinematics_params_filename="$(find xarm_description)/config/kinematics/default/xarm7_default_kinematics.yaml"/>
  </xacro:if>
  <xacro:if value="${hw_mode == 'sim'}">
    <xacro:xarm7_robot prefix="" hw_ns="xarm" limited="false"
      velocity_control="false" add_gripper="false"
      ros2_control_plugin="mock_components/GenericSystem"
      robot_ip="" report_type="normal"
      model_num="0"
      kinematics_params_filename="$(find xarm_description)/config/kinematics/default/xarm7_default_kinematics.yaml"/>
  </xacro:if>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- HITBOT Z-Arm S922 (offset on Y axis)                           -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <joint name="hitbot_world_joint" type="fixed">
    <parent link="world"/>
    <child  link="hitbot_base"/>
    <origin xyz="0 ${hitbot_y} 0" rpy="1.5707963267948966 0 0"/>
  </joint>

  <!-- HITBOT base link (= S922_1 in the original URDF) -->
  <link name="hitbot_base">
    <inertial>
      <origin xyz="-0.00031896 0.04246343 0.00029674" rpy="0 0 0"/>
      <mass value="4.705646"/>
      <inertia ixx="0.008965" iyy="0.013144" izz="0.008962"
               ixy="-0.000056" iyz="0.000052" ixz="-0.000045"/>
    </inertial>
    <visual name="hitbot_base_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision name="hitbot_base_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="hitbot_link2">
    <inertial>
      <origin xyz="-0.00000032 -0.00409121 0.07230568" rpy="0 0 0"/>
      <mass value="12.729169"/>
      <inertia ixx="0.032499" iyy="0.031555" izz="0.023788"
               ixy="-0.00000002" iyz="0.00029660" ixz="0.00000031"/>
    </inertial>
    <visual name="hitbot_link2_visual">
      <origin xyz="0 0 -0.074" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision name="hitbot_link2_collision">
      <origin xyz="0 0 -0.074" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="hitbot_link3">
    <inertial>
      <origin xyz="-0.00000004 0.21250020 0.07454833" rpy="0 0 0"/>
      <mass value="42.003389"/>
      <inertia ixx="1.323848" iyy="0.082405" izz="1.306099"
               ixy="0.00000022" iyz="0.00000001" ixz="-0.00000011"/>
    </inertial>
    <visual name="hitbot_link3_visual">
      <origin xyz="-0.152 0 -0.06" rpy="0 0 -1.5707963267948903"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision name="hitbot_link3_collision">
      <origin xyz="-0.152 0 -0.06" rpy="0 0 -1.5707963267948903"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-3.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="hitbot_link4">
    <inertial>
      <origin xyz="-0.18891210 0 0.05460834" rpy="0 0 0"/>
      <mass value="22.416777"/>
      <inertia ixx="0.025305" iyy="0.502160" izz="0.498261"
               ixy="-0.00000007" iyz="0" ixz="0.022051"/>
    </inertial>
    <visual name="hitbot_link4_visual">
      <origin xyz="0.42500003 0.152 0.06100001" rpy="3.141592653589793 0 0"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision name="hitbot_link4_collision">
      <origin xyz="0.42500003 0.152 0.06100001" rpy="3.141592653589793 0 0"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-4.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="hitbot_link5">
    <inertial>
      <origin xyz="-0.00254890 0.00013287 0.04396255" rpy="0 0 0"/>
      <mass value="4.835242"/>
      <inertia ixx="0.004563" iyy="0.006790" izz="0.006292"
               ixy="-0.00000002" iyz="-0.000000005" ixz="0.00006271"/>
    </inertial>
    <visual name="hitbot_link5_visual">
      <origin xyz="-0.15186732 -0.81987736 -0.05320002" rpy="0 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision name="hitbot_link5_collision">
      <origin xyz="-0.15186732 -0.81987736 -0.05320002" rpy="0 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-5.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="hitbot_link6">
    <inertial>
      <origin xyz="0.04134111 0.00275669 0.00000058" rpy="0 0 0"/>
      <mass value="4.703461"/>
      <inertia ixx="0.006198" iyy="0.004277" izz="0.006503"
               ixy="-0.000047" iyz="0.00000012" ixz="0.00000001"/>
    </inertial>
    <visual name="hitbot_link6_visual">
      <origin xyz="0.095 -0.10200002 -0.82001003" rpy="-1.5707963267276066 1.5707963267948963 0"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision name="hitbot_link6_collision">
      <origin xyz="0.095 -0.10200002 -0.82001003" rpy="-1.5707963267276066 1.5707963267948963 0"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="hitbot_link7">
    <inertial>
      <origin xyz="-0.00007587 0.00002409 0.01912195" rpy="0 0 0"/>
      <mass value="1.527602"/>
      <inertia ixx="0.000807" iyy="0.000808" izz="0.001210"
               ixy="0.00000150" iyz="-0.00000074" ixz="-0.00000004"/>
    </inertial>
    <visual name="hitbot_link7_visual">
      <origin xyz="0 0 -0.0038" rpy="1.5707963269294802 0 -1.5707963267948972"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-7.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision name="hitbot_link7_collision">
      <origin xyz="0 0 -0.0038" rpy="1.5707963269294802 0 -1.5707963267948972"/>
      <geometry>
        <mesh filename="package://hitbot_description/meshes/S922-7.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- HITBOT joints (identical kinematics to the user's original hitbot.urdf) -->
  <joint name="hitbot_joint1" type="revolute">
    <origin xyz="0 0.075 0" rpy="-1.5707963267948966 0 0"/>
    <parent link="hitbot_base"/>
    <child  link="hitbot_link2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0543" upper="3.0543" effort="50.0" velocity="3.14"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="hitbot_joint2" type="revolute">
    <origin xyz="0 -0.06100001 0.07799999" rpy="1.5707963267948966 0 0"/>
    <parent link="hitbot_link2"/>
    <child  link="hitbot_link3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-4.6251" upper="1.4835" effort="50.0" velocity="3.14"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="hitbot_joint3" type="revolute">
    <origin xyz="0 0.42500003 0" rpy="3.141592653589793 0 3.141592653589793"/>
    <parent link="hitbot_link3"/>
    <child  link="hitbot_link4"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.7925" upper="2.7925" effort="50.0" velocity="3.14"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="hitbot_joint4" type="revolute">
    <origin xyz="-0.39501 0 0.00279999" rpy="3.141592653589793 0 0"/>
    <parent link="hitbot_link4"/>
    <child  link="hitbot_link5"/>
    <axis xyz="0 0 1"/>
    <limit lower="-4.6251" upper="1.4835" effort="50.0" velocity="3.14"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="hitbot_joint5" type="revolute">
    <origin xyz="-0.05806732 0.00013267 0.0488" rpy="1.5707963267948963 0 3.141592653589793"/>
    <parent link="hitbot_link5"/>
    <child  link="hitbot_link6"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.0543" upper="3.0543" effort="50.0" velocity="3.14"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="hitbot_joint6" type="revolute">
    <origin xyz="0.045 0.0582 0" rpy="1.5707963267948968 0 -3.1415926535225007"/>
    <parent link="hitbot_link6"/>
    <child  link="hitbot_link7"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0543" upper="3.0543" effort="50.0" velocity="3.14"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- ros2_control for HITBOT                                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <xacro:if value="${hw_mode == 'sim'}">
    <ros2_control name="HitbotMockSystem" type="system">
      <hardware>
        <plugin>mock_components/GenericSystem</plugin>
      </hardware>
      <joint name="hitbot_joint1">
        <command_interface name="position"><param name="min">-3.0543</param><param name="max">3.0543</param></command_interface>
        <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="hitbot_joint2">
        <command_interface name="position"><param name="min">-4.6251</param><param name="max">1.4835</param></command_interface>
        <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="hitbot_joint3">
        <command_interface name="position"><param name="min">-2.7925</param><param name="max">2.7925</param></command_interface>
        <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="hitbot_joint4">
        <command_interface name="position"><param name="min">-4.6251</param><param name="max">1.4835</param></command_interface>
        <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="hitbot_joint5">
        <command_interface name="position"><param name="min">-3.0543</param><param name="max">3.0543</param></command_interface>
        <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
      <joint name="hitbot_joint6">
        <command_interface name="position"><param name="min">-3.0543</param><param name="max">3.0543</param></command_interface>
        <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
  </xacro:if>

  <xacro:if value="${hw_mode == 'real'}">
    <ros2_control name="HitbotRealSystem" type="system">
      <hardware>
        <plugin>hitbot_hardware/HitbotHardwareInterface</plugin>
        <param name="robot_ip">${hitbot_ip}</param>
        <param name="robot_port">${hitbot_port}</param>
      </hardware>
      <joint name="hitbot_joint1">
        <command_interface name="position"><param name="min">-3.0543</param><param name="max">3.0543</param></command_interface>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
      </joint>
      <joint name="hitbot_joint2">
        <command_interface name="position"><param name="min">-4.6251</param><param name="max">1.4835</param></command_interface>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
      </joint>
      <joint name="hitbot_joint3">
        <command_interface name="position"><param name="min">-2.7925</param><param name="max">2.7925</param></command_interface>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
      </joint>
      <joint name="hitbot_joint4">
        <command_interface name="position"><param name="min">-4.6251</param><param name="max">1.4835</param></command_interface>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
      </joint>
      <joint name="hitbot_joint5">
        <command_interface name="position"><param name="min">-3.0543</param><param name="max">3.0543</param></command_interface>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
      </joint>
      <joint name="hitbot_joint6">
        <command_interface name="position"><param name="min">-3.0543</param><param name="max">3.0543</param></command_interface>
        <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
      </joint>
    </ros2_control>
  </xacro:if>

</robot>
